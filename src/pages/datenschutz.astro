---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Datenschutz">
  <div class="container static-page">
    <h1>Datenschutzerklärung</h1>
    <p class="lead">FIXME: Datenschutzerklärung gemäß DSGVO ergänzen.</p>

    <h2>Verantwortlicher</h2>
    <p>FIXME: Name und Kontakt des Verantwortlichen.</p>

    <h2>Hosting</h2>
    <p>FIXME: Informationen zum Hosting (Server-Standort, Anbieter).</p>

    <h2>Cookies</h2>
    <p>Diese Website verwendet keine Tracking-Cookies.</p>

    <h2>Ihre Rechte</h2>
    <p>
      Sie haben das Recht auf Auskunft, Berichtigung, Löschung und Einschränkung der
      Verarbeitung Ihrer personenbezogenen Daten.
    </p>
  </div>
</BaseLayout>

<style>
  .static-page { max-width: 52rem; padding-block: 3rem; }
  h1 { font-size: 2rem; font-weight: 700; margin-bottom: 1.25rem; letter-spacing: -0.03em; }
  h2 { font-size: 1.2rem; font-weight: 600; margin: 2rem 0 0.75rem; }
  .lead { font-size: 1.1rem; color: #555; margin-bottom: 1.5rem; }
  p { line-height: 1.7; margin-bottom: 1em; }
</style>
