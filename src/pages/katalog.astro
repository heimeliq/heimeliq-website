---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getPublishedFurniture } from '../lib/furniture-data.js';
import { getAllSeries } from '../lib/series.js';

const furniture = await getPublishedFurniture();
const series = getAllSeries();
---
<BaseLayout
  title="Katalog"
  description="Alle publizierten heimeliQ-Möbel im Überblick – filterbar nach Reihe."
>
  <div class="container catalog-page">
    <h1>Katalog</h1>
    <p class="subtitle">
      {furniture.length} {furniture.length === 1 ? 'Möbel' : 'Möbel'} veröffentlicht
    </p>

    <!-- Filter-Leiste (vanilla JS, kein Framework) -->
    <div class="filter-bar" role="group" aria-label="Nach Reihe filtern">
      <button class="filter-btn active" data-filter="all">Alle</button>
      {series.map(s => (
        <button class="filter-btn" data-filter={s.id}>{s.name}</button>
      ))}
    </div>

    {furniture.length === 0 ? (
      <p class="empty-note">Noch keine Möbel veröffentlicht.</p>
    ) : (
      <div class="furniture-grid" id="catalog-grid">
        {furniture.map(item => (
          <a
            href={`/moebel/${item.slug}`}
            class="furniture-card"
            data-series={item.series}
          >
            <div class="furniture-card-img">
              <img
                src={`/moebel/${item.slug}/media/hero.jpg`}
                alt={item.name}
                loading="lazy"
              />
            </div>
            <div class="furniture-card-body">
              <span class="series-badge">{item.series}</span>
              <h2>{item.name}</h2>
              <span class="version">v{item.version}</span>
            </div>
          </a>
        ))}
      </div>
    )}
  </div>
</BaseLayout>

<!-- Vanilla-JS-Filter: keine Abhängigkeit, kein Framework -->
<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const cards = document.querySelectorAll<HTMLElement>('.furniture-card');

  buttons.forEach(btn => {
    btn.addEventListener('click', () => {
      const filter = btn.dataset.filter ?? 'all';
      buttons.forEach(b => b.classList.toggle('active', b === btn));
      cards.forEach(card => {
        const match = filter === 'all' || card.dataset.series === filter;
        card.style.display = match ? '' : 'none';
      });
    });
  });
</script>

<style>
  .catalog-page { padding-block: 2rem 4rem; }
  h1 { font-size: clamp(1.75rem, 4vw, 2.5rem); font-weight: 700; letter-spacing: -0.03em; }
  .subtitle { color: #888; margin-top: 0.25rem; margin-bottom: 1.75rem; }

  .filter-bar {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-bottom: 1.75rem;
  }
  .filter-btn {
    padding: 0.4rem 0.9rem;
    border: 1px solid #ddd;
    border-radius: 20px;
    background: none;
    cursor: pointer;
    font-size: 0.85rem;
    transition: background 0.15s, border-color 0.15s;
  }
  .filter-btn:hover { border-color: #aaa; }
  .filter-btn.active { background: #1a1a1a; color: #fff; border-color: #1a1a1a; }

  .empty-note { color: #888; }

  .furniture-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1.5rem;
  }
  .furniture-card {
    border: 1px solid #e5e5e5;
    border-radius: 6px;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition: box-shadow 0.15s;
  }
  .furniture-card:hover { box-shadow: 0 2px 12px rgba(0,0,0,0.08); }
  .furniture-card-img { aspect-ratio: 4/3; background: #f0ede8; overflow: hidden; }
  .furniture-card-img img { width: 100%; height: 100%; object-fit: cover; }
  .furniture-card-body { padding: 1rem; }
  .series-badge {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #888;
    display: block;
    margin-bottom: 0.2rem;
  }
  .furniture-card-body h2 { font-size: 1rem; font-weight: 600; margin-bottom: 0.2rem; }
  .version { font-size: 0.8rem; color: #bbb; }
</style>
