---
import { marked } from 'marked';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getPublishedFurniture, type FurnitureItem } from '../../lib/furniture-data.js';
import { getSeries } from '../../lib/series.js';
import { buildFurniturePage } from '../../lib/furniture-page.js';

export async function getStaticPaths() {
  const items = await getPublishedFurniture();
  return items.map(item => ({
    params: { slug: item.slug },
    props: { item },
  }));
}

const { item } = Astro.props as { item: FurnitureItem };
const seriesData = getSeries(item.series);
const page = buildFurniturePage(item);
const readmeHtml = await marked(page.readmeContent);
const fnText = String(item.okh.function ?? '').replace(/\n/g, ' ').slice(0, 160);
---
<BaseLayout title={item.name} description={fnText}>
  <!-- Hero -->
  <div class="hero-image-wrap">
    <img
      src={`/moebel/${item.slug}/media/hero.jpg`}
      alt={`Hauptbild: ${item.name}`}
      class="hero-image"
    />
  </div>

  <div class="container page-content">
    <nav class="breadcrumb">
      <a href="/">Startseite</a> /
      {seriesData && <><a href={`/reihen/${item.series}`}>{seriesData.name}</a> / </>}
      {item.name}
    </nav>

    <header class="moebel-header">
      {seriesData && (
        <a href={`/reihen/${item.series}`} class="series-link">{seriesData.name}</a>
      )}
      <h1>{item.name}</h1>
      <span class="version-badge">v{item.version} · CERN-OHL-S-2.0</span>
    </header>

    <!-- Maße -->
    {(page.dim || page.massKg) && (
      <section class="specs-section">
        <h2>Maße</h2>
        <table class="specs-table">
          <tbody>
            {page.dim && (
              <>
                <tr><th>Breite</th><td>{page.dim.width} mm</td></tr>
                <tr><th>Tiefe</th><td>{page.dim.depth} mm</td></tr>
                <tr><th>Höhe</th><td>{page.dim.height} mm</td></tr>
              </>
            )}
            {page.massKg && <tr><th>Masse</th><td>{page.massKg} kg</td></tr>}
          </tbody>
        </table>
      </section>
    )}

    <!-- Stückliste -->
    {(page.ownParts.length > 0 || page.extParts.length > 0) && (
      <section class="bom-section">
        <h2>Stückliste</h2>

        {page.ownParts.length > 0 && (
          <>
            <h3>Eigene Bauteile</h3>
            <table class="bom-table">
              <thead>
                <tr><th>ID</th><th>Bezeichnung</th><th>Maße (B×T×H, mm)</th><th>Masse</th></tr>
              </thead>
              <tbody>
                {page.ownParts.map(p => (
                  <tr>
                    <td class="mono">{p.id}</td>
                    <td>{p.name}</td>
                    <td class="mono">{p.dim}</td>
                    <td>{p.mass}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </>
        )}

        {page.extParts.length > 0 && (
          <>
            <h3>Externe Teile</h3>
            <table class="bom-table">
              <thead>
                <tr><th>ID</th><th>Bezeichnung</th><th>Norm / Maß</th><th>Menge</th></tr>
              </thead>
              <tbody>
                {page.extParts.map(p => (
                  <tr>
                    <td class="mono">{p.id}</td>
                    <td>{p.name}</td>
                    <td>{p.spec}</td>
                    <td>{p.qty}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </>
        )}
      </section>
    )}

    <!-- Downloads -->
    {page.downloads.length > 0 && (
      <section class="downloads-section">
        <h2>Downloads</h2>
        <ul class="download-list">
          {page.downloads.map(dl => (
            <li>
              <a href={dl.href} download class="download-link">
                <span class="ext-badge">{dl.ext}</span>
                {dl.label}
              </a>
            </li>
          ))}
        </ul>
      </section>
    )}

    <!-- Galerie -->
    {page.galleryImages.length > 0 && (
      <section class="gallery-section">
        <h2>Galerie</h2>
        <div class="gallery-grid">
          {page.galleryImages.map(src => (
            <img src={src} alt="" loading="lazy" class="gallery-img" />
          ))}
        </div>
      </section>
    )}

    <!-- README / Dokumentation -->
    <section class="readme-section">
      <h2>Dokumentation</h2>
      <div class="prose" set:html={readmeHtml} />
    </section>
  </div>
</BaseLayout>

<style>
  .hero-image-wrap { width: 100%; max-height: 55vh; overflow: hidden; background: #f0ede8; }
  .hero-image { width: 100%; height: 55vh; object-fit: cover; display: block; }

  .page-content { padding-block: 2rem 4rem; }

  .breadcrumb { font-size: 0.85rem; color: #888; margin-bottom: 2rem; }
  .breadcrumb a { color: inherit; text-decoration: none; }
  .breadcrumb a:hover { text-decoration: underline; }

  .moebel-header { margin-bottom: 2.5rem; }
  .series-link {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: #888;
    text-decoration: none;
    display: block;
    margin-bottom: 0.4rem;
  }
  .series-link:hover { color: #555; }
  .moebel-header h1 {
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    margin-bottom: 0.4rem;
  }
  .version-badge { font-size: 0.8rem; color: #aaa; }

  .specs-section, .bom-section, .downloads-section, .gallery-section, .readme-section {
    margin-bottom: 3rem;
  }
  .specs-section h2, .bom-section h2, .downloads-section h2,
  .gallery-section h2, .readme-section h2 {
    font-size: 1.2rem;
    font-weight: 600;
    margin-bottom: 0.75rem;
    padding-bottom: 0.4rem;
    border-bottom: 1px solid #e5e5e5;
  }
  .bom-section h3 { font-size: 1rem; font-weight: 600; margin: 1.25rem 0 0.5rem; }

  .specs-table, .bom-table {
    border-collapse: collapse;
    font-size: 0.9rem;
    width: 100%;
    max-width: 52rem;
  }
  .specs-table th, .bom-table th {
    text-align: left;
    font-weight: 600;
    padding: 0.4rem 1rem 0.4rem 0;
    color: #555;
    white-space: nowrap;
  }
  .specs-table td, .bom-table td { padding: 0.4rem 1rem 0.4rem 0; }
  .bom-table thead th { border-bottom: 1px solid #e5e5e5; padding-bottom: 0.5rem; }
  .bom-table tbody tr:nth-child(even) { background: #fafafa; }
  .mono { font-family: var(--font-mono); font-size: 0.85em; }

  .download-list { list-style: none; display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .download-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.4rem 0.75rem;
    border: 1px solid #ddd;
    border-radius: 4px;
    text-decoration: none;
    color: inherit;
    font-size: 0.85rem;
    transition: border-color 0.15s;
  }
  .download-link:hover { border-color: #aaa; }
  .ext-badge {
    font-size: 0.7rem;
    font-weight: 700;
    background: #eee;
    padding: 0.1rem 0.35rem;
    border-radius: 3px;
  }

  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 0.75rem;
  }
  .gallery-img {
    width: 100%;
    aspect-ratio: 4/3;
    object-fit: cover;
    border-radius: 4px;
    background: #f0ede8;
  }

  .prose :global(h1) { display: none; }
  .prose :global(h2) { font-size: 1.1rem; font-weight: 600; margin: 1.75em 0 0.5em; }
  .prose :global(h3) { font-size: 1rem; font-weight: 600; margin: 1.25em 0 0.4em; }
  .prose :global(p) { margin-bottom: 0.9em; line-height: 1.7; max-width: 70ch; }
  .prose :global(table) { border-collapse: collapse; font-size: 0.88rem; margin-bottom: 1rem; }
  .prose :global(th), .prose :global(td) {
    padding: 0.35rem 0.75rem;
    border: 1px solid #e5e5e5;
    text-align: left;
  }
  .prose :global(th) { background: #f5f5f5; font-weight: 600; }
  .prose :global(img) { max-width: 100%; border-radius: 4px; margin-block: 0.75rem; }
  .prose :global(a) { color: #1a1a1a; }
  .prose :global(code) {
    font-family: var(--font-mono);
    font-size: 0.85em;
    background: #f0f0f0;
    padding: 0.1em 0.3em;
    border-radius: 3px;
  }
</style>
