---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getPublishedFurniture } from '../../lib/furniture-data.js';
import { getAllSeries } from '../../lib/series.js';
import { marked } from 'marked';

export async function getStaticPaths() {
  const series = getAllSeries();
  return series.map(s => ({ params: { series: s.id } }));
}

const { series: seriesId } = Astro.params;
const allSeries = getAllSeries();
const seriesData = allSeries.find(s => s.id === seriesId);
if (!seriesData) throw new Error(`Reihe nicht gefunden: ${seriesId}`);

const allFurniture = await getPublishedFurniture();
const furnitureInSeries = allFurniture.filter(i => i.series === seriesId);

const storyHtml = seriesData.story ? await marked(seriesData.story) : '';
---
<BaseLayout title={seriesData.name} description={seriesData.tagline}>
  <div class="container">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/">Startseite</a> / Reihen / {seriesData.name}
    </nav>

    <header class="series-header">
      <h1>{seriesData.name}</h1>
      <p class="tagline">{seriesData.tagline}</p>
    </header>

    {storyHtml && (
      <section class="story prose" set:html={storyHtml} />
    )}

    <section class="furniture-section">
      <h2>Möbel dieser Reihe</h2>
      {furnitureInSeries.length === 0 ? (
        <p class="empty-note">Noch keine Möbel in dieser Reihe veröffentlicht.</p>
      ) : (
        <div class="furniture-grid">
          {furnitureInSeries.map(item => (
            <a href={`/moebel/${item.slug}`} class="furniture-card">
              <div class="furniture-card-img">
                <img
                  src={`/moebel/${item.slug}/media/hero.jpg`}
                  alt={item.name}
                  loading="lazy"
                />
              </div>
              <div class="furniture-card-body">
                <h3>{item.name}</h3>
                <span class="version">v{item.version}</span>
              </div>
            </a>
          ))}
        </div>
      )}
    </section>
  </div>
</BaseLayout>

<style>
  .container { padding-block: 2rem; }
  .breadcrumb { font-size: 0.85rem; color: #888; margin-bottom: 2rem; }
  .breadcrumb a { color: inherit; text-decoration: none; }
  .breadcrumb a:hover { text-decoration: underline; }

  .series-header { margin-bottom: 2rem; }
  .series-header h1 {
    font-size: clamp(1.75rem, 4vw, 3rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    margin-bottom: 0.5rem;
  }
  .tagline { font-size: 1.1rem; color: #555; }

  .story {
    max-width: 52rem;
    margin-bottom: 3rem;
    padding: 2rem;
    background: #f8f6f3;
    border-radius: 6px;
  }

  /* prose reset */
  .prose :global(h1),
  .prose :global(h2),
  .prose :global(h3) { margin-top: 1.5em; margin-bottom: 0.5em; font-weight: 600; }
  .prose :global(p) { margin-bottom: 1em; line-height: 1.7; }

  .furniture-section h2 { font-size: 1.25rem; font-weight: 600; margin-bottom: 1.25rem; }
  .empty-note { color: #888; }

  .furniture-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1.5rem;
  }
  .furniture-card {
    border: 1px solid #e5e5e5;
    border-radius: 6px;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition: box-shadow 0.15s;
  }
  .furniture-card:hover { box-shadow: 0 2px 12px rgba(0,0,0,0.08); }
  .furniture-card-img { aspect-ratio: 4/3; background: #f0ede8; overflow: hidden; }
  .furniture-card-img img { width: 100%; height: 100%; object-fit: cover; }
  .furniture-card-body { padding: 1rem; }
  .furniture-card-body h3 { font-size: 1rem; font-weight: 600; margin-bottom: 0.25rem; }
  .version { font-size: 0.8rem; color: #999; }
</style>
